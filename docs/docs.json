{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "maple",
  "name": "AronaApi",
  "colors": {
    "primary": "#8b5cf6",
    "light": "#a78bfa",
    "dark": "#7c3aed"
  },
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg",
    "href": "https://api.lingshichat.top"
  },
  "navbar": {
    "links": [
      {
        "type": "github",
        "href": "https://github.com/QuantumNous/new-api"
      },
      {
        "label": "API Status",
        "href": "https://api.lingshichat.top"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Console",
      "href": "https://api.lingshichat.top"
    }
  },
  "navigation": {
    "languages": [
      {
        "language": "cn",
        "default": true,
        "groups": [
          {
            "group": "快速开始",
            "pages": [
              "cn/index",
              "cn/quickstart",
              "cn/authentication"
            ]
          },
          {
            "group": "API 文档",
            "pages": [
              "cn/api/overview",
              "cn/api/chat-completions",
              "cn/api/models",
              "cn/api/embeddings",
              "cn/api/images"
            ]
          },
          {
            "group": "功能",
            "pages": [
              "cn/guides/models",
              "cn/guides/pricing",
              "cn/guides/channels"
            ]
          },
          {
            "group": "集成",
            "pages": [
              "cn/guides/mcp"
            ]
          }
        ]
      },
      {
        "language": "en",
        "groups": [
          {
            "group": "Get Started",
            "pages": [
              "en/index",
              "en/quickstart",
              "en/authentication"
            ]
          },
          {
            "group": "API Reference",
            "pages": [
              "en/api/overview",
              "en/api/chat-completions",
              "en/api/models",
              "en/api/embeddings",
              "en/api/images"
            ]
          },
          {
            "group": "Features",
            "pages": [
              "en/guides/models",
              "en/guides/pricing",
              "en/guides/channels"
            ]
          },
          {
            "group": "Integrations",
            "pages": [
              "en/guides/mcp"
            ]
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "API Status",
          "icon": "signal",
          "href": "https://api.lingshichat.top"
        },
        {
          "anchor": "Community",
          "icon": "users",
          "href": "https://docs.newapi.pro/support/community-interaction/"
        }
      ]
    }
  },
  "footerSocials": {
    "github": "https://github.com/QuantumNous/new-api"
  },
  "feedback": {
    "thumbsRating": true,
    "suggestEdit": true
  },
  "search": {
    "prompt": "Search documentation..."
  }
