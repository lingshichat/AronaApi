{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "maple",
  "name": "AronaApi",
  "colors": {
    "primary": "#8b5cf6",
    "light": "#a78bfa",
    "dark": "#7c3aed"
  },
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg",
    "href": "https://api.lingshichat.top"
